# ──────────────────────────────────────────────
# Brave Rewards Refueler — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
# All variables are optional during development;
# missing values cause graceful degradation, not crashes.

# Payment provider: "stripe" | "transak" | "none"
PAYMENT_PROVIDER=none

# Shared secret for webhook HMAC verification
# Stripe: Your webhook signing secret from Dashboard → Webhooks
# Transak: Your webhook secret from Transak Partner Dashboard
WEBHOOK_SECRET=

# Solana RPC endpoint (Helius, QuickNode, or public)
# Example: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_URL=

# Hot wallet private key (base58 encoded byte array, base64'd)
# Generate: solana-keygen new --outfile hot-wallet.json
# Then: cat hot-wallet.json | jq -r '.[0:32]' | base64
HOT_WALLET_PRIVATE_KEY=

# Domain (used for CORS and links)
NEXT_PUBLIC_DOMAIN=top-up-brave-rewards.wallet-warden.one
